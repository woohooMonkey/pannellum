[
  {
    "name": "change_theme",
    "description": "改变应用的主题颜色",
    "parameters": {
      "type": "object",
      "properties": {
        "color": { "type": "string", "description": "颜色值，如 red, #ff0000" }
      },
      "required": ["color"]
    },
    "frontend": {
      "handler": "ui.setTheme", 
      "comment": "调用前端 UI 模块的 setTheme 方法"
    },
    "backend": {
      "log": true,
      "comment": "后端记录操作日志"
    }
  },
  {
    "name": "show_notification",
    "description": "在屏幕右上角显示通知消息",
    "parameters": {
      "type": "object",
      "properties": {
        "message": { "type": "string", "description": "通知内容" },
        "type": { "type": "string", "enum": ["info", "success", "error"] }
      },
      "required": ["message"]
    },
    "frontend": {
      "handler": "toast.show",
      "comment": "调用前端 Toast 组件"
    },
    "backend": {
      "log": false
    }
  }
]